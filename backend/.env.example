# ── Telegram ─────────────────────────────────────────
BOT_TOKEN=123456:replace-with-your-bot-token
BOT_USERNAME=allfoodsuzbot
TMA_URL=https://your-tma-domain.example

# Prod CORS origin'lari (vergul bilan). Bo'sh bo'lsa faqat TMA_URL ruxsat etiladi.
ADMIN_URL=https://your-admin-domain.example
COURIER_URL=https://your-courier-domain.example

# ── Auth ─────────────────────────────────────────────
# Uzun tasodifiy: python -c "import secrets;print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Prod'da: ENVIRONMENT=production (CORS wildcard o'chadi).
ENVIRONMENT=development
API_BASE_URL=http://localhost:8000

# ── Database ─────────────────────────────────────────
# POSTGRES_HOST=postgres → Docker service name. Use localhost for local dev.
POSTGRES_USER=allfoods
POSTGRES_PASSWORD=allfoods
POSTGRES_DB=allfoods
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Har bir gunicorn worker'ning DB pool hajmi. Jami ulanish ~= WEB_CONCURRENCY *
# (DB_POOL_SIZE + DB_MAX_OVERFLOW) — Postgres max_connections'dan oshmasin.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Gunicorn worker (process) soni — server core soniga qarab oshiring.
WEB_CONCURRENCY=4

# ── Redis ────────────────────────────────────────────
# redis://redis:6379/0 → Docker service name. Use localhost for local dev.
REDIS_URL=redis://redis:6379/0

# ── Web Push (VAPID) — generate once:
#   python -c "from py_vapid import Vapid01; from py_vapid.utils import b64urlencode; \
#   from cryptography.hazmat.primitives import serialization as s; v=Vapid01(); v.generate_keys(); \
#   print(b64urlencode(v.private_key.private_numbers().private_value.to_bytes(32,'big'))); \
#   print(b64urlencode(v.public_key.public_bytes(s.Encoding.X962, s.PublicFormat.UncompressedPoint)))"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@allfoods.uz

# ── Admin bootstrap (first superuser) ────────────────
# Kuchli parol qo'ying — bu birinchi superadmin hisobini yaratadi.
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=change-me-strong-password

# Platform superadmin bootstrap (biz) — the account for /platform/auth/login
FIRST_PLATFORM_USERNAME=platform
FIRST_PLATFORM_PASSWORD=change-me-in-production

# ── Optional: chat that receives new-order alerts ────
# ORDERS_CHAT_ID=-1001234567890
