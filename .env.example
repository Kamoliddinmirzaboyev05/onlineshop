# Root .env — used ONLY by docker-compose for ${POSTGRES_*} interpolation
# of the `postgres` service. Per-app config lives in:
#   backend/.env   (Telegram, Auth, DB, Redis, Admin)  → see backend/.env.example
#   tma/.env       (VITE_API_URL)                       → see tma/.env.example
#   admin/.env     (VITE_API_URL)                       → see admin/.env.example
POSTGRES_USER=allfoods
POSTGRES_PASSWORD=allfoods
POSTGRES_DB=allfoods
